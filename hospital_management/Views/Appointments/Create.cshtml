@model hospital_management.Models.Appointment

@{
    ViewData["Title"] = "Book Appointment";
}

<h2>Book Appointment</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="PatientId"></label>
        <select asp-for="PatientId" class="form-control" asp-items="ViewBag.PatientId"></select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DoctorId"></label>
        <select asp-for="DoctorId" class="form-control" asp-items="ViewBag.DoctorId"></select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="AppointmentDate"></label>
        <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">Book Appointment</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back to List</a>
</form>
