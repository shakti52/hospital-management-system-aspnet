@model hospital_management.Models.Prescription

@{
    ViewData["Title"] = "Add Prescription";
}

<h2>Add Prescription</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-3">
        <label asp-for="PatientId"></label>
        <select asp-for="PatientId" class="form-control" asp-items="ViewBag.PatientId"></select>
        <span asp-validation-for="PatientId" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Medication"></label>
        <textarea asp-for="Medication" class="form-control"></textarea>
        <span asp-validation-for="Medication" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Notes"></label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">Add Prescription</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back to List</a>
</form>
