@model hospital_management.Models.Doctors

@{
    ViewData["Title"] = "Add Doctor";
}

<h2>Add Doctor</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Specialization"></label>
        <input asp-for="Specialization" class="form-control" />
        <span asp-validation-for="Specialization" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">Add Doctor</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back to List</a>
</form>
